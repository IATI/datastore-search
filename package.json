{
    "name": "datastore-search",
    "version": "1.12.1",
    "type": "module",
    "scripts": {
        "start": "npm run dev",
        "dev": "vite --mode development",
        "dev:production": "vite --mode production",
        "build:development": "vite build --mode development",
        "build:production": "vite build --mode production",
        "serve": "serve -s dist",
        "preview": "vite preview",
        "cy:open": "cypress open --config-file cypress.config.local.js",
        "cy:open-ci": "cypress open --config-file cypress.config.ci.js",
        "cy:open-dev": "cypress open --config-file cypress.config.dev.js",
        "cy:open-prod": "cypress open --config-file cypress.config.prod.js",
        "cy:run": "cypress run --config-file cypress.config.local.js",
        "cy:run-ci": "cypress run --config-file cypress.config.ci.js",
        "cy:run-dev": "cypress run --config-file cypress.config.dev.js",
        "cy:run-prod": "cypress run --config-file cypress.config.prod.js",
        "lint": "npm run lint:eslint && npm run lint:prettier",
        "lint:eslint": "eslint .",
        "lint:prettier": "prettier . --check",
        "format": "prettier . --write",
        "prepare": "husky",
        "savepo": "node locale/po/js2po.js",
        "loadpo": "node locale/po/po2js.js > locale/fr/index.js"
    },
    "dependencies": {
        "@hennge/vue3-pagination": "^1.0.17",
        "@heroicons/vue": "^2.2.0",
        "axios": "^1.7.9",
        "crypto-js": "^4.2.0",
        "date-fns": "^4.1.0",
        "leaflet": "^1.9.4",
        "plausible-tracker": "^0.3.9",
        "split.js": "^1.6.5",
        "vue": "^3.5.13",
        "vue-i18n": "^11.4.2",
        "vue-multiselect": "^3.1.0",
        "vue-router": "^5.0.7",
        "vue3-datepicker": "^0.4.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/leaflet": "^1.9.15",
        "@types/leaflet.markercluster": "^1.5.5",
        "@vitejs/plugin-vue": "^6.0.0",
        "autoprefixer": "^10.4.20",
        "cypress": "^13.16.0",
        "cypress-file-upload": "^5.0.8",
        "eslint": "^9.39.4",
        "eslint-config-flat-gitignore": "^0.1.5",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-cypress": "^3.5.0",
        "eslint-plugin-vue": "^9.32.0",
        "globals": "^15.11.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.0",
        "pofile": "^1.1.4",
        "postcss": "^8.4.49",
        "prettier": "3.8.3",
        "serve": "^14.2.4",
        "tailwindcss": "^3.4.16",
        "typescript": ">=4.7.4 <6.1.0",
        "typescript-eslint": "^8.9.0",
        "vite": "^8.0.0"
    },
    "lint-staged": {
        "*": "npm run format"
    },
    "engines": {
        "node": "24.x.x",
        "npm": "11.x.x"
    }
}
